@inject ITimelineService Timeline
@implements IDisposable

@if (Timeline.SelectedEntry is { } entry)
{
    <div class="step-detail">
        @if (entry.TestName is not null)
        {
            <div class="step-test-name" title="@entry.TestName">@GetShortTestName(entry.TestName)</div>
        }
        <div class="step-header">
            <span class="step-badge @(entry.HasError ? "badge-error" : "badge-success")">@entry.ActionType</span>
            @if (entry.Selector is not null)
            {
                <code class="step-selector">@entry.Selector</code>
            }
            <span class="step-duration">@entry.Duration.TotalMilliseconds.ToString("F0")ms</span>
            <span class="step-time">@entry.Timestamp.ToString("HH:mm:ss.fff")</span>
        </div>

        @if (entry.ErrorMessage is not null)
        {
            <div class="step-error">@entry.ErrorMessage</div>
        }

        <div class="step-screenshots">
            @if (entry.ScreenshotBefore is not null)
            {
                <div class="screenshot-col">
                    <span class="screenshot-label">Before</span>
                    <img src="data:image/png;base64,@Convert.ToBase64String(entry.ScreenshotBefore)" alt="Before" />
                </div>
            }
            @if (entry.ScreenshotAfter is not null)
            {
                <div class="screenshot-col">
                    <span class="screenshot-label">After</span>
                    <img src="data:image/png;base64,@Convert.ToBase64String(entry.ScreenshotAfter)" alt="After" />
                </div>
            }
        </div>

        @if (entry.NetworkRequests.Count > 0)
        {
            <details class="step-section">
                <summary>Network (@entry.NetworkRequests.Count)</summary>
                <table class="network-table">
                    <thead>
                        <tr><th>Method</th><th>URL</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var req in entry.NetworkRequests)
                        {
                            <tr class="@(req.Failed ? "row-failed" : "")">
                                <td>@req.Method</td>
                                <td class="url-cell">@req.Url</td>
                                <td>@(req.Failed ? "FAIL" : req.StatusCode.ToString())</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </details>
        }

        @if (entry.ConsoleMessages.Count > 0)
        {
            <details class="step-section">
                <summary>Console (@entry.ConsoleMessages.Count)</summary>
                <div class="console-list">
                    @foreach (var msg in entry.ConsoleMessages)
                    {
                        <div class="console-entry console-@msg.Type">[@msg.Type] @msg.Text</div>
                    }
                </div>
            </details>
        }

        @if (entry.PerformanceMetrics is { } pm)
        {
            <details class="step-section" open>
                <summary>Performance</summary>
                <table class="network-table">
                    <thead>
                        <tr><th>Metric</th><th>Value</th></tr>
                    </thead>
                    <tbody>
                        @if (pm.Lcp is not null)
                        {
                            <tr><td>LCP</td><td>@($"{pm.Lcp:F1}ms")</td></tr>
                        }
                        @if (pm.Fcp is not null)
                        {
                            <tr><td>FCP</td><td>@($"{pm.Fcp:F1}ms")</td></tr>
                        }
                        @if (pm.Ttfb is not null)
                        {
                            <tr><td>TTFB</td><td>@($"{pm.Ttfb:F1}ms")</td></tr>
                        }
                        @if (pm.Cls is not null)
                        {
                            <tr><td>CLS</td><td>@($"{pm.Cls:F4}")</td></tr>
                        }
                        @if (pm.Inp is not null)
                        {
                            <tr><td>INP</td><td>@($"{pm.Inp:F1}ms")</td></tr>
                        }
                        @if (pm.JsHeapSize is not null)
                        {
                            <tr><td>JS Heap</td><td>@($"{pm.JsHeapSize:N0} bytes")</td></tr>
                        }
                        @if (pm.DomNodeCount is not null)
                        {
                            <tr><td>DOM Nodes</td><td>@pm.DomNodeCount</td></tr>
                        }
                    </tbody>
                </table>
            </details>
        }
    </div>
}
else
{
    <div class="step-empty">Select a step from the timeline to view details</div>
}

@code {
    private static string GetShortTestName(string fullName)
    {
        var parts = fullName.Split('.');
        // Show ClassName.MethodName
        return parts.Length >= 2 ? $"{parts[^2]}.{parts[^1]}" : fullName;
    }

    protected override void OnInitialized()
    {
        Timeline.TimelineChanged += OnTimelineChanged;
    }

    private async void OnTimelineChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Timeline.TimelineChanged -= OnTimelineChanged;
    }
}
