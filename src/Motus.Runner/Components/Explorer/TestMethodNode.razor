@inject ITestSessionService Session
@implements IDisposable

<div class="method-node" @onclick="RunTest" title="@Test.FullName">
    <TestStatusBadge Status="@CurrentStatus" />
    <span class="method-name">@Test.TestMethod.Name</span>
    @if (CurrentState?.Duration is not null)
    {
        <span class="method-duration">@($"{CurrentState.Duration.Value.TotalMilliseconds:F0}ms")</span>
    }
</div>

@code {
    [Parameter, EditorRequired] public DiscoveredTest Test { get; set; } = null!;

    private TestNodeState? CurrentState =>
        Session.States.TryGetValue(Test.FullName, out var state) ? state : null;

    private TestStatus CurrentStatus => CurrentState?.Status ?? TestStatus.Pending;

    protected override void OnInitialized()
    {
        Session.StateChanged += OnStateChanged;
    }

    private async Task RunTest()
    {
        if (!Session.IsRunning)
        {
            await Session.RunTestAsync(Test.FullName);
        }
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.StateChanged -= OnStateChanged;
    }
}
