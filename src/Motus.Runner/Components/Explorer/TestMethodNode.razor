@inject ITestSessionService Session
@inject ITimelineService Timeline
@inject RunnerOptions Options
@implements IDisposable

<div class="method-node" @onclick="OnClick" title="@Tooltip">
    <TestStatusBadge Status="@CurrentStatus" />
    <span class="method-name">@MethodDisplayName</span>
    @if (CurrentState?.Duration is not null)
    {
        <span class="method-duration">@($"{CurrentState.Duration.Value.TotalMilliseconds:F0}ms")</span>
    }
</div>

@code {
    [Parameter, EditorRequired] public DiscoveredTest Test { get; set; } = null!;

    private TestNodeState? CurrentState =>
        Session.States.TryGetValue(Test.FullName, out var state) ? state : null;

    private TestStatus CurrentStatus => CurrentState?.Status ?? TestStatus.Pending;

    private string MethodDisplayName => Test.TestMethod?.Name ?? GetMethodFromFullName(Test.FullName);

    private string Tooltip => CurrentStatus == TestStatus.Skipped && CurrentState?.ErrorMessage is not null
        ? $"{Test.FullName}\n{CurrentState.ErrorMessage}"
        : Test.FullName;

    protected override void OnInitialized()
    {
        Session.StateChanged += OnStateChanged;
    }

    private async Task OnClick()
    {
        if (Options.ViewerMode == ViewerMode.Trx)
        {
            Timeline.SelectTest(Test.FullName);
            return;
        }

        if (!Session.IsRunning && !Test.IsIgnored)
        {
            await Session.RunTestAsync(Test.FullName);
        }
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.StateChanged -= OnStateChanged;
    }

    private static string GetMethodFromFullName(string fullName)
    {
        var dot = fullName.LastIndexOf('.');
        return dot > 0 && dot + 1 < fullName.Length ? fullName[(dot + 1)..] : fullName;
    }
}
