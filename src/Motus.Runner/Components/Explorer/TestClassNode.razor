@inject ITestSessionService Session
@implements IDisposable

<div class="class-node">
    <div class="class-header" @onclick="Toggle">
        <span class="chevron">@(Expanded ? "\u25BE" : "\u25B8")</span>
        <TestStatusBadge Status="@AggregateStatus" />
        <span class="class-name" title="@ClassName">@DisplayName</span>
        <button class="run-class-btn" @onclick="RunClass" @onclick:stopPropagation="true"
                disabled="@Session.IsRunning" title="Run Class">&#9654;</button>
    </div>
    @if (Expanded)
    {
        @foreach (var test in Tests)
        {
            <TestMethodNode Test="@test" />
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public string ClassName { get; set; } = "";
    [Parameter, EditorRequired] public string DisplayName { get; set; } = "";
    [Parameter, EditorRequired] public List<DiscoveredTest> Tests { get; set; } = [];

    private bool Expanded { get; set; } = true;

    private TestStatus AggregateStatus => TestSuiteNode.GetAggregateStatus(Tests, Session.States);

    protected override void OnInitialized()
    {
        Session.StateChanged += OnStateChanged;
    }

    private void Toggle() => Expanded = !Expanded;

    private async Task RunClass()
    {
        await Session.RunClassAsync(ClassName);
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.StateChanged -= OnStateChanged;
    }
}
