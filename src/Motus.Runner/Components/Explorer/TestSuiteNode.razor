@inject ITestSessionService Session
@implements IDisposable

<div class="suite-node">
    <div class="suite-header" @onclick="Toggle">
        <span class="chevron">@(Expanded ? "\u25BE" : "\u25B8")</span>
        <TestStatusBadge Status="@AggregateStatus" />
        <span class="suite-name" title="@AssemblyName">@AssemblyName</span>
        <span class="suite-count">(@Tests.Count)</span>
    </div>
    @if (Expanded)
    {
        @foreach (var classGroup in Tests.GroupBy(t => t.TestClass.FullName ?? t.TestClass.Name))
        {
            <TestClassNode ClassName="@classGroup.Key"
                           DisplayName="@classGroup.First().TestClass.Name"
                           Tests="@classGroup.ToList()" />
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public string AssemblyName { get; set; } = "";
    [Parameter, EditorRequired] public List<DiscoveredTest> Tests { get; set; } = [];

    private bool Expanded { get; set; } = true;

    private TestStatus AggregateStatus => GetAggregateStatus(Tests, Session.States);

    protected override void OnInitialized()
    {
        Session.StateChanged += OnStateChanged;
    }

    private void Toggle() => Expanded = !Expanded;

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.StateChanged -= OnStateChanged;
    }

    internal static TestStatus GetAggregateStatus(List<DiscoveredTest> tests, IReadOnlyDictionary<string, TestNodeState> states)
    {
        var hasRunning = false;
        var hasFailed = false;
        var hasPassed = false;
        var hasSkipped = false;
        var hasPending = false;

        foreach (var test in tests)
        {
            if (states.TryGetValue(test.FullName, out var state))
            {
                switch (state.Status)
                {
                    case TestStatus.Failed: hasFailed = true; break;
                    case TestStatus.Running: hasRunning = true; break;
                    case TestStatus.Passed: hasPassed = true; break;
                    case TestStatus.Skipped: hasSkipped = true; break;
                    default: hasPending = true; break;
                }
            }
            else
            {
                hasPending = true;
            }
        }

        if (hasFailed) return TestStatus.Failed;
        if (hasRunning) return TestStatus.Running;
        if (hasPassed && !hasPending) return TestStatus.Passed;
        if (hasSkipped && !hasPassed && !hasFailed && !hasPending) return TestStatus.Skipped;
        return TestStatus.Pending;
    }
}
