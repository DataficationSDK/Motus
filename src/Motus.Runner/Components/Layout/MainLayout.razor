@inherits LayoutComponentBase
@inject ITestSessionService Session
@inject ITimelineService Timeline
@inject ICoverageService Coverage
@inject RunnerOptions Options
@implements IDisposable

<div class="runner-shell" id="runner-shell"
     style="@(Options.TraceMode ? "grid-template-columns: 1fr; grid-template-areas: 'toolbar' 'main' 'resize' 'bottom';" : "")">
    <div class="runner-toolbar">
        <RunnerToolbar />
    </div>
    @if (!Options.TraceMode)
    {
        <div class="runner-sidebar" id="runner-sidebar">
            <TestExplorer />
        </div>
        <div class="sidebar-resize-handle" id="sidebar-resize-handle"></div>
    }
    <div class="runner-main">
        <div class="main-tabs">
            <button class="main-tab @(activeTab == "browser" ? "tab-active" : "")"
                    @onclick='() => activeTab = "browser"'>
                Browser View
            </button>
            <button class="main-tab @(activeTab == "step" ? "tab-active" : "")"
                    @onclick='() => activeTab = "step"'>
                Step Detail
            </button>
            <button class="main-tab @(activeTab == "vr" ? "tab-active" : "")"
                    @onclick='() => activeTab = "vr"'>
                Visual Regression
            </button>
            <button class="main-tab @(activeTab == "console" ? "tab-active" : "")"
                    @onclick='() => activeTab = "console"'>
                Test Console
            </button>
            @if (Options.RepairMode)
            {
                <button class="main-tab @(activeTab == "repair" ? "tab-active" : "")"
                        @onclick='() => activeTab = "repair"'>
                    Selector Repair
                </button>
            }
            @if (Coverage.HasData)
            {
                <button class="main-tab @(activeTab == "coverage" ? "tab-active" : "")"
                        @onclick='() => activeTab = "coverage"'>
                    Coverage
                </button>
            }
        </div>
        <div class="main-content">
            @switch (activeTab)
            {
                case "browser":
                    <BrowserViewPanel />
                    break;
                case "step":
                    <StepDetailPanel />
                    break;
                case "vr":
                    <VisualRegressionPanel />
                    break;
                case "console":
                    <TestConsolePanel />
                    break;
                case "repair":
                    <SelectorRepairPanel />
                    break;
                case "coverage":
                    <CoveragePanel />
                    break;
            }
        </div>
    </div>
    <div class="runner-resize-handle" id="resize-handle"></div>
    <div class="runner-bottom" id="runner-bottom">
        <TimelinePanel />
    </div>
</div>

<script suppress-error="BL9992">
    (function() {
        // Bottom panel resize
        const handle = document.getElementById('resize-handle');
        const bottom = document.getElementById('runner-bottom');
        if (handle && bottom) {
            let startY, startH;
            handle.addEventListener('pointerdown', e => {
                startY = e.clientY;
                startH = bottom.offsetHeight;
                handle.setPointerCapture(e.pointerId);
                document.body.style.userSelect = 'none';
                document.body.style.cursor = 'row-resize';
            });
            handle.addEventListener('pointermove', e => {
                if (startY == null) return;
                const delta = startY - e.clientY;
                const h = Math.max(36, Math.min(window.innerHeight * 0.5, startH + delta));
                bottom.style.height = h + 'px';
            });
            handle.addEventListener('pointerup', e => {
                startY = null;
                handle.releasePointerCapture(e.pointerId);
                document.body.style.userSelect = '';
                document.body.style.cursor = '';
            });
        }

        // Sidebar resize
        const sideHandle = document.getElementById('sidebar-resize-handle');
        const sidebar = document.getElementById('runner-sidebar');
        const shell = document.getElementById('runner-shell');
        if (sideHandle && sidebar && shell) {
            let startX, startW;
            sideHandle.addEventListener('pointerdown', e => {
                startX = e.clientX;
                startW = sidebar.offsetWidth;
                sideHandle.setPointerCapture(e.pointerId);
                document.body.style.userSelect = 'none';
                document.body.style.cursor = 'col-resize';
            });
            sideHandle.addEventListener('pointermove', e => {
                if (startX == null) return;
                const delta = e.clientX - startX;
                const w = Math.max(150, Math.min(window.innerWidth * 0.5, startW + delta));
                shell.style.gridTemplateColumns = w + 'px auto 1fr';
            });
            sideHandle.addEventListener('pointerup', e => {
                startX = null;
                sideHandle.releasePointerCapture(e.pointerId);
                document.body.style.userSelect = '';
                document.body.style.cursor = '';
            });
        }
    })();
</script>

@code {
    private string activeTab = "browser";
    private int? lastSelectedIndex;

    protected override void OnInitialized()
    {
        if (Options.TraceMode)
            activeTab = "step";
        if (Options.RepairMode)
            activeTab = "repair";
        Session.StateChanged += OnStateChanged;
        Session.RunStarted += OnRunStarted;
        Timeline.TimelineChanged += OnTimelineChanged;
        Timeline.TestSelected += OnTestSelected;
        Coverage.CoverageChanged += OnCoverageChanged;
    }

    private async void OnCoverageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void OnRunStarted()
    {
        activeTab = "browser";
        await InvokeAsync(StateHasChanged);
    }

    private async void OnTimelineChanged()
    {
        // Auto-switch to Step Detail when a timeline entry is selected
        var idx = Timeline.SelectedIndex;
        if (idx is not null && idx != lastSelectedIndex)
        {
            lastSelectedIndex = idx;
            activeTab = "step";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async void OnTestSelected()
    {
        // Don't switch away from Browser View while tests are running;
        // the auto-selection is for tracking the active test, not changing tabs
        if (!Session.IsRunning)
            activeTab = "console";
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.StateChanged -= OnStateChanged;
        Session.RunStarted -= OnRunStarted;
        Timeline.TimelineChanged -= OnTimelineChanged;
        Timeline.TestSelected -= OnTestSelected;
        Coverage.CoverageChanged -= OnCoverageChanged;
    }
}
